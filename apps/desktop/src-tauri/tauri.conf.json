{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hengji",
  "version": "0.4.1",
  "identifier": "com.hengji.dev",
  "build": {
    "beforeDevCommand": "pnpm --filter @app/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @app/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "衡记 Héng",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
